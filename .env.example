# Optional approved wine data bridge.
# Frontend override. Leave blank to use the bundled Vercel /api/wine-lookup bridge.
VITE_WINE_LOOKUP_API_URL=

# Optional Supabase auth/cloud persistence.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional server-side approved provider settings for api/wine-lookup.ts.
# Configure these in Vercel project environment variables, not in frontend code.
WINE_PROVIDER_API_URL=
WINE_PROVIDER_API_KEY=
